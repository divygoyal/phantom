# Phantom — Autonomous Creator Agent
# Copy to .env.local and fill in keys

# === Database ===
DATABASE_URL="file:./phantom.db"

# === LLM brain ===
# Options:
#   scripted     - Use pre-baked responses (default; no API needed, demo-ready)
#   claude-code  - Shell out to local `claude` CLI (uses your Claude Pro/Max subscription)
#   anthropic    - Use Anthropic API (requires ANTHROPIC_API_KEY)
LLM_PROVIDER=scripted

# Only needed if LLM_PROVIDER=anthropic
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# === HeyGen (avatar, lipsync, translate, video agent) ===
# Get one at https://app.heygen.com/settings (API tab)
HEYGEN_API_KEY=

# === Fal (FLUX images for thumbnails + B-roll) ===
# Get one at https://fal.ai/dashboard/keys ($10 free credit on signup)
FAL_KEY=

# === PostHog (analytics + agent's read-back loop) ===
# Personal API key for HogQL read-back
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=

# (Optional) Project write key for client-side event capture
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# === Channel + HeyGen assets ===
CHANNEL_HANDLE=@aisimplified

# Voice imported from ElevenLabs (Raunak M)
HEYGEN_VOICE_ID=1856084cf0ee4e139de4bbb02035a02c

# Avatar look ID (run `mcp__heygen__list_avatar_looks` to find yours)
HEYGEN_AVATAR_LOOK_ID=
HEYGEN_AVATAR_GROUP_ID=

# Gemini (fallback for image generation)
GEMINI_API_KEY=
